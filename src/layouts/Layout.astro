---
import '~/styles/styles.css';
import SEO from './SEO.astro';
import TopBar from '~/components/TopBar.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import Hero from '~/components/Hero.astro';
import { BUSINESS } from '~/data/business';

export interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
  // Backwards-compatible: pages still pass heroTitle / heroSubtitle.
  // When set, Layout auto-renders the inner-page Hero so pages don't have to.
  heroTitle?: string;
  heroSubtitle?: string;
  // New: pages can disable the auto-hero (e.g., the homepage which renders its own).
  noHero?: boolean;
}

const {
  title,
  description,
  canonicalURL,
  ogImage,
  heroTitle,
  heroSubtitle,
  noHero = false,
} = Astro.props;

const shouldRenderHero = !noHero && Boolean(heroTitle);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/images/icon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#facc15" />
    <meta name="google-site-verification" content="az0vfIYzdWThop57VbZ6qfZ085oMnRRZUsz7JSchKsU" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-4DNFF1D67L"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-4DNFF1D67L');
    </script>

    <SEO
      title={title}
      description={description}
      canonicalURL={canonicalURL}
      ogImage={ogImage}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <TopBar />
    <Header />

    {shouldRenderHero && (
      <Hero variant="inner" title={heroTitle!} subtitle={heroSubtitle} />
    )}

    <main id="main">
      <slot />
    </main>

    <Footer />
  </body>
</html>
