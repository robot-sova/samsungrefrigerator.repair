---
import Layout from '~/layouts/Layout.astro';
import CallCTA from '~/components/CallCTA.astro';
import RelatedLinks from '~/components/RelatedLinks.astro';
import FAQ from '~/components/FAQ.astro';
import { ERROR_CODES } from '~/data/errorCodes';
import { SERVICES } from '~/data/services';
import { COUNTIES } from '~/data/locations';
import { BUSINESS } from '~/data/business';

export async function getStaticPaths() {
  return ERROR_CODES.map((code) => ({
    params: { slug: code.slug },
    props: { code },
  }));
}

const { code } = Astro.props;
const description = `Samsung ${code.code} error: what it means, what to try, and when to call. ${BUSINESS.phoneDisplay}.`;
const relatedService = code.relatedServiceSlug
  ? SERVICES.find((s) => s.slug === code.relatedServiceSlug)
  : undefined;
---

<Layout
  title={`${code.title} | ${BUSINESS.phoneDisplay}`}
  description={description.slice(0, 160)}
  heroTitle={code.title}
  heroSubtitle={`Samsung ${code.code} error — diagnosis, what to try, and when to call`}
>
  <div class="maintext">
    <h2>What "{code.code}" Means</h2>
    <p>{code.meaning}</p>
  </div>

  <div class="maintext">
    <h2>Common Root Causes</h2>
    <ul>
      {code.rootCauses.map((c) => <li>{c}</li>)}
    </ul>
  </div>

  <div class="maintext">
    <h2>What You Can Try First</h2>
    <ul>
      {code.whatToTry.map((step) => <li>{step}</li>)}
    </ul>
  </div>

  <div class="maintext">
    <h2>When to Call a Pro</h2>
    <p>{code.whenToCallPro}</p>
  </div>

  <div class="maintext">
    <h2>How We Fix It</h2>
    <p>{code.howWeFix}</p>
  </div>

  {relatedService && (
    <div class="maintext">
      <h2>Related Repair Service</h2>
      <p>
        <a style="color:#fff; font-weight:700;" href={`/services/${relatedService.slug}/`}>
          {relatedService.title}
        </a>
        &nbsp;— {relatedService.shortDescription}
      </p>
    </div>
  )}

  <div class="maintext">
    <h2>Available in All Five Counties</h2>
    <ul>
      {COUNTIES.map((county) => (
        <li>
          <a style="color:#fff; font-weight:700;" href={`/service-area/${county.slug}/`}>
            Samsung {code.code} repair in {county.name}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <FAQ faqs={code.faq.map((f) => ({ question: f.q, answer: f.a }))} />

  <RelatedLinks excludeErrorCodeSlug={code.slug} />

  <div class="maintext">
    <CallCTA />
  </div>
</Layout>
