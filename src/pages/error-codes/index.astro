---
import Layout from '~/layouts/Layout.astro';
import ErrorCodesGrid from '~/components/ErrorCodesGrid.astro';
import CallCTA from '~/components/CallCTA.astro';
import { BUSINESS } from '~/data/business';

const title = `Samsung Refrigerator Error Codes | ${BUSINESS.phoneDisplay}`;
const description = `Samsung refrigerator error code reference: 1E, 5E, 8E, 21E, 22E, 41C, 84C, OF OF, PC ER. What each means and when to call. ${BUSINESS.phoneDisplay}.`;
---

<Layout title={title} description={description} pageTitle="Samsung Refrigerator Error Codes">
  <div class="maintext">
    <p>
      Samsung refrigerator panels report faults as short alphanumeric codes. The list below covers
      the codes we see most often on service calls — what each one means, what you can safely try,
      and when to stop and call a tech.
    </p>
    <CallCTA />
  </div>

  <ErrorCodesGrid heading="All Samsung Refrigerator Error Codes" />
</Layout>
