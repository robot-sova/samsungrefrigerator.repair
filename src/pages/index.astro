---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero.astro';
import TrustStrip from '~/components/TrustStrip.astro';
import ServicesGrid from '~/components/ServicesGrid.astro';
import ServiceAreaSection from '~/components/ServiceAreaSection.astro';
import ErrorCodesPreview from '~/components/ErrorCodesPreview.astro';
import WhyChooseUs from '~/components/WhyChooseUs.astro';
import Reviews from '~/components/Reviews.astro';
import FAQ from '~/components/FAQ.astro';
import FinalCTA from '~/components/FinalCTA.astro';
import { BUSINESS } from '~/data/business';

const title = `Samsung Refrigerator Repair | Same-Day Service | ${BUSINESS.phoneDisplay}`;
const description = `Same-day Samsung refrigerator repair across ${BUSINESS.areasServed.join(', ')}. Family Hub, Bespoke, French Door, side-by-side. Call ${BUSINESS.phoneDisplay}.`;

const homeFaqs = [
  {
    question: 'Do you offer same-day Samsung refrigerator repair?',
    answer:
      'Yes — most calls received before noon can be scheduled the same day across our five service counties. Booking is open 24/7 and our service hours are Mon–Sun 8:00 AM – 8:00 PM.',
  },
  {
    question: 'Which Samsung refrigerator models do you service?',
    answer:
      'All current Samsung refrigerator lines: Family Hub, Bespoke, French Door, 4-Door FlexZone, side-by-side, and top-freezer models. We also service older Samsung models still under common parts availability.',
  },
  {
    question: 'How much does a Samsung refrigerator repair cost?',
    answer:
      'A diagnostic visit covers travel, inspection, and a written quote. Repair pricing depends on the part — common ice-maker and sensor failures fall in a different range than compressor or sealed-system work. We always quote before any repair.',
  },
  {
    question: 'Do you fix Samsung ice makers?',
    answer:
      'Yes — Samsung ice makers (especially the French Door ice room) are one of the most common calls we run. We carry the most-failed parts on the truck.',
  },
  {
    question: 'What areas do you cover?',
    answer: `${BUSINESS.areasServed.join(', ')}. We do not currently serve outside these five counties.`,
  },
  {
    question: 'Are you Samsung-certified?',
    answer:
      'We work exclusively on Samsung refrigerators, install genuine OEM parts, and follow Samsung-published service procedures. Our techs are factory-trained on the platforms we service.',
  },
];
---

<Layout title={title} description={description} noHero={true}>
  <Hero
    variant="home"
    kicker="Samsung-certified specialists"
    title="Samsung Refrigerator Repair Across Southern California"
    subtitle="Same-day service in Los Angeles, Orange, Riverside, San Bernardino, and Ventura counties. Factory-trained techs, OEM parts, honest pricing."
    showCTAs={true}
    showTrust={true}
  />

  <TrustStrip />

  <ServicesGrid
    heading="What we fix"
    intro="From ice maker freeze-ups to compressor failures — we handle every Samsung refrigerator problem."
  />

  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <h2>Samsung specialists since 2010</h2>
      </div>
      <div style="max-width: 760px; margin: 0 auto;">
        <p style="font-size: 1.05rem; margin-bottom: 12px;">
          We're a mobile Samsung refrigerator repair service running same-day calls across five
          Southern California counties — Los Angeles, Orange, Riverside, San Bernardino, and Ventura.
          Samsung is our specialty, not a side line. Our trucks carry the parts that fail most on
          Samsung French Door, 4-Door FlexZone, Family Hub, Bespoke, side-by-side, and top-freezer
          models, so most repairs finish on the first visit.
        </p>
        <p style="font-size: 1.05rem; margin-bottom: 12px;">
          Samsung refrigerators have well-documented failure modes — the French Door ice maker
          freeze-up, the defrost-system fault that warms the fridge while the freezer stays cold,
          the inverter board that throws an 84C code and looks like a dead compressor. Knowing
          those patterns is the difference between a single-visit fix and a misdiagnosis. We won't
          replace a $400 main board when the actual failure is a $40 sensor.
        </p>
        <p style="font-size: 1.05rem;">
          Booking is open 24/7. Service hours run Mon–Sun 8:00 AM – 8:00 PM. Calls received before
          noon generally get a same-day arrival window. Diagnostics include a written quote, and
          no work starts until you approve the price.
        </p>
      </div>
    </div>
  </section>

  <ServiceAreaSection />

  <ErrorCodesPreview />

  <WhyChooseUs />

  <Reviews />

  <FAQ faqs={homeFaqs} asSection={true} />

  <FinalCTA />
</Layout>
