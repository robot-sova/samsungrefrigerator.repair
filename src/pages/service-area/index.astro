---
import Layout from '~/layouts/Layout.astro';
import CountiesGrid from '~/components/CountiesGrid.astro';
import CallCTA from '~/components/CallCTA.astro';
import { BUSINESS } from '~/data/business';

const title = `Samsung Refrigerator Repair Service Area | ${BUSINESS.phoneDisplay}`;
const description = `Samsung refrigerator repair across ${BUSINESS.areasServed.join(', ')}. Pick your county to see cities served. Call ${BUSINESS.phoneDisplay}.`;
---

<Layout
  title={title}
  description={description}
  heroTitle="Samsung Refrigerator Repair Service Area"
  heroSubtitle="Five Southern California counties — pick yours to see cities served"
>
  <div class="maintext">
    <p>
      We run service calls across {BUSINESS.areasServed.length} Southern California counties:
      {BUSINESS.areasServed.join(', ')}. Pick your county to see the cities we cover and book a same-day visit.
    </p>
  </div>

  <CountiesGrid heading="Choose Your County" />

  <div class="maintext">
    <CallCTA />
  </div>
</Layout>
