---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero.astro';
import ServiceAreaSection from '~/components/ServiceAreaSection.astro';
import FinalCTA from '~/components/FinalCTA.astro';
import { BUSINESS } from '~/data/business';

const title = `Samsung Refrigerator Repair Service Area | ${BUSINESS.phoneDisplay}`;
const description = `Samsung refrigerator repair across ${BUSINESS.areasServed.join(', ')}. Pick your county to see cities served. Call ${BUSINESS.phoneDisplay}.`;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Area' },
];
---

<Layout title={title} description={description} noHero={true}>
  <Hero
    variant="inner"
    breadcrumbs={breadcrumbs}
    title="Samsung Refrigerator Repair Service Area"
    subtitle="Five Southern California counties — pick yours to see cities served."
  />

  <ServiceAreaSection
    heading="Counties we serve"
    intro={`We run service calls across ${BUSINESS.areasServed.length} Southern California counties: ${BUSINESS.areasServed.join(', ')}.`}
  />

  <FinalCTA />
</Layout>
