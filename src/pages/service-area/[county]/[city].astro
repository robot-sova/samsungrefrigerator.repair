---
import Layout from '~/layouts/Layout.astro';
import CallCTA from '~/components/CallCTA.astro';
import RelatedLinks from '~/components/RelatedLinks.astro';
import FAQ from '~/components/FAQ.astro';
import { COUNTIES } from '~/data/locations';
import { SERVICES } from '~/data/services';
import { BUSINESS } from '~/data/business';

export async function getStaticPaths() {
  return COUNTIES.flatMap((county) =>
    county.cities.map((city) => ({
      params: { county: county.slug, city: city.slug },
      props: { county, city },
    }))
  );
}

const { county, city } = Astro.props;

const openings = [
  `If your Samsung refrigerator just stopped cooling in ${city.name}, you're not alone — Samsung calls are the single most common service we run in ${county.name}.`,
  `Samsung refrigerator repair in ${city.name} is what we do every day. Most ${city.name} calls book same-day, and we carry the most-failed Samsung parts on the truck.`,
  `${city.name} homes lean heavily on Samsung French Door and Family Hub refrigerators, and they all share a similar set of failure points — ice maker freeze-ups, defrost faults, and the occasional inverter board.`,
  `When a Samsung refrigerator fails in ${city.name}, the clock starts on the food inside. Our ${county.name} dispatch covers ${city.name} same-day for calls that land before noon.`,
  `For ${city.name} households, a dead Samsung refrigerator means a fast trip to the store and a slow trip back. We run Samsung-only service trucks across ${county.name}, so most ${city.name} repairs finish on the first visit.`,
];
const middles = [
  `Most calls fall into a familiar pattern: the freezer is fine but the fridge is warm (defrost or fan issue), the ice maker has frozen itself solid (the well-known Samsung French Door ice room issue), or the compressor will not start (inverter board or compressor itself).`,
  `Common Samsung issues we fix in ${city.name} include warm-fridge / cold-freezer splits, ice makers that build a frost block in the ice room, water leaks tracing back to a clogged defrost drain, and 84C / 41C / PC ER errors on the panel.`,
  `Across ${city.name} we see a familiar mix of Samsung complaints — ice maker no-ice or freeze-up, fridge section warming while the freezer stays cold, dispenser leaks, and panel error codes that point at sensors or boards.`,
];
const closings = [
  `Same-day service is the goal whenever the schedule allows. Booking is open 24/7, and our service hours run ${BUSINESS.hoursDisplay}.`,
  `Booking is open 24/7. We confirm a same-day arrival window when the call lands before noon.`,
  `Our diagnostic visit covers travel and a written quote. Repair pricing is presented before any work starts — no surprise charges.`,
];

const hash = (s: string) => s.split('').reduce((a, c) => (a * 31 + c.charCodeAt(0)) >>> 0, 0);
const h = hash(`${county.slug}|${city.slug}`);
const opener = openings[h % openings.length]!;
const middle = middles[(h >>> 3) % middles.length]!;
const closer = closings[(h >>> 5) % closings.length]!;

const cityIdx = county.cities.findIndex((c) => c.slug === city.slug);
const before = county.cities.slice(Math.max(0, cityIdx - 2), cityIdx);
const after = county.cities.slice(cityIdx + 1, cityIdx + 4);
const nearby = [...before, ...after].slice(0, 3);

const description = `Samsung refrigerator repair in ${city.name}, ${county.name}, CA. Same-day Samsung service. Call ${BUSINESS.phoneDisplay}.`;

const faqs = [
  {
    question: `Do you offer same-day Samsung refrigerator repair in ${city.name}?`,
    answer: `Yes — calls received before noon in ${city.name} usually receive same-day service. Service hours are ${BUSINESS.hoursDisplay}.`,
  },
  {
    question: `What is the most common Samsung refrigerator issue in ${city.name}?`,
    answer: `The Samsung French Door ice maker freeze-up is the single most common Samsung call we run in ${city.name} and across ${county.name}. The fridge-side warming-up issue (defrost system fault) is a close second.`,
  },
  {
    question: `Do you service all Samsung refrigerator models in ${city.name}?`,
    answer: `Yes — Family Hub, Bespoke, French Door, 4-Door FlexZone, side-by-side, and top-freezer Samsung refrigerators. Have your model number ready when you call so we can confirm parts.`,
  },
];

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Samsung Refrigerator Repair',
  provider: {
    '@type': 'LocalBusiness',
    name: BUSINESS.name,
    telephone: BUSINESS.phoneDisplay,
    email: BUSINESS.email,
    url: BUSINESS.siteUrl,
  },
  areaServed: {
    '@type': 'City',
    name: city.name,
    containedInPlace: {
      '@type': 'AdministrativeArea',
      name: county.name,
      containedInPlace: { '@type': 'State', name: 'California' },
    },
  },
  name: `Samsung Refrigerator Repair in ${city.name}, CA`,
  description,
};
---

<Layout
  title={`Samsung Refrigerator Repair in ${city.name}, CA | ${BUSINESS.phoneDisplay}`}
  description={description}
  heroTitle={`Samsung Refrigerator Repair in ${city.name}, CA`}
  heroSubtitle={`Same-day Samsung service in ${city.name}, ${county.name}`}
>
  <div class="maintext">
    <!-- TODO: rewrite with localized content -->
    <p>{opener}</p>
    <p>{middle}</p>
    <p>{closer}</p>
  </div>

  <div class="maintext">
    <h2>Samsung Repair Services Available in {city.name}</h2>
    <ul>
      {SERVICES.map((s) => (
        <li>
          <a style="color:#fff; font-weight:700;" href={`/services/${s.slug}/`}>{s.title}</a>
          <span style="color:#cfcfcf;"> — {s.shortDescription}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="maintext">
    <h2>Common Samsung Refrigerator Issues in {city.name}</h2>
    <ul>
      <li>Samsung French Door ice maker freeze-ups</li>
      <li>Fridge section warming while freezer stays cold (defrost system)</li>
      <li>Water leaks from the dispenser line or defrost drain</li>
      <li>Inverter / compressor failures (84C error)</li>
      <li>Display board communication errors (41C, PC ER)</li>
      <li>Door gasket failure causing frost buildup</li>
    </ul>
    <CallCTA />
  </div>

  <FAQ faqs={faqs} heading={`Samsung Refrigerator Repair FAQ — ${city.name}`} />

  {nearby.length > 0 && (
    <div class="maintext">
      <h2>Nearby Cities We Also Serve</h2>
      <ul>
        {nearby.map((nc) => (
          <li>
            <a style="color:#fff; font-weight:700;" href={`/service-area/${county.slug}/${nc.slug}/`}>
              Samsung Refrigerator Repair in {nc.name}
            </a>
          </li>
        ))}
      </ul>
      <p>
        See <a style="color:#fff; font-weight:700;" href={`/service-area/${county.slug}/`}>all {county.name} cities</a>.
      </p>
    </div>
  )}

  <RelatedLinks countySlug={county.slug} citySlug={city.slug} />

  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
</Layout>
