---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero.astro';
import StickyCTACard from '~/components/StickyCTACard.astro';
import ServicesGrid from '~/components/ServicesGrid.astro';
import FAQ from '~/components/FAQ.astro';
import FinalCTA from '~/components/FinalCTA.astro';
import { COUNTIES } from '~/data/locations';
import { BUSINESS } from '~/data/business';

export async function getStaticPaths() {
  return COUNTIES.map((county) => ({
    params: { county: county.slug },
    props: { county },
  }));
}

const { county } = Astro.props;

const description = `Samsung refrigerator repair in ${county.name}, CA. Same-day service across ${county.cities.length} cities. Call ${BUSINESS.phoneDisplay}.`;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Area', href: '/service-area/' },
  { label: county.name },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(c.href ? { item: new URL(c.href, BUSINESS.siteUrl).toString() } : {}),
  })),
};

const faqs = [
  {
    question: `How fast can you get to me in ${county.name}?`,
    answer: `Same-day service is available across ${county.name} when calls land before noon. Calls after noon usually book the next morning.`,
  },
  {
    question: `Do you charge a trip fee in ${county.name}?`,
    answer: `Our diagnostic visit fee covers travel anywhere in ${county.name}. The visit fee is waived if you proceed with the recommended repair.`,
  },
  {
    question: `Which Samsung refrigerator issues do you fix in ${county.name}?`,
    answer: `Every Samsung refrigerator service we offer — not cooling, ice maker, water leaks, freezer issues, compressor, control board, door seals, error codes — is available in all ${county.cities.length} cities we cover in ${county.name}.`,
  },
];
---

<Layout
  title={`Samsung Refrigerator Repair in ${county.name}, CA | ${BUSINESS.phoneDisplay}`}
  description={description}
  noHero={true}
>
  <Hero
    variant="inner"
    breadcrumbs={breadcrumbs}
    title={`Samsung Refrigerator Repair in ${county.name}, CA`}
    subtitle={`Same-day service across ${county.cities.length} cities in ${county.name}.`}
  />

  <div class="container section">
    <div class="page-grid">
      <div class="page-main">
        <div class="prose-block">
          <p>{county.intro}</p>
          <p>
            All {county.cities.length} cities below get the same dispatch priority and the same
            truck-stocked Samsung parts inventory.
          </p>
        </div>

        <div class="prose-block">
          <h2>Cities we serve in {county.name}</h2>
          <ul>
            {county.cities.map((city) => (
              <li>
                <a href={`/service-area/${county.slug}/${city.slug}/`}>
                  Samsung refrigerator repair in {city.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="prose-block">
          <FAQ faqs={faqs} heading={`${county.name} FAQ`} />
        </div>
      </div>

      <aside class="page-sidebar">
        <StickyCTACard context={`Same-day Samsung service across ${county.name}.`} />
      </aside>
    </div>
  </div>

  <ServicesGrid
    heading="Samsung repair services across this county"
    intro="All 9 services available in every city we cover."
  />

  <FinalCTA />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
