---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero.astro';
import ServicesGrid from '~/components/ServicesGrid.astro';
import FinalCTA from '~/components/FinalCTA.astro';
import { BUSINESS } from '~/data/business';

const title = `Samsung Refrigerator Repair Services | ${BUSINESS.phoneDisplay}`;
const description = `All Samsung refrigerator repair services we offer — not cooling, ice maker, leaks, compressor, control board, error codes. Call ${BUSINESS.phoneDisplay}.`;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Services' },
];
---

<Layout title={title} description={description} noHero={true}>
  <Hero
    variant="inner"
    breadcrumbs={breadcrumbs}
    title="Samsung Refrigerator Repair Services"
    subtitle="Same-day service across all 5 Southern California counties we cover."
  />

  <ServicesGrid
    heading="What we fix"
    intro="Pick the symptom that matches what you're seeing — every Samsung refrigerator repair we run falls into one of these categories."
  />

  <FinalCTA />
</Layout>
