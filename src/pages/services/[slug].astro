---
import Layout from '~/layouts/Layout.astro';
import CallCTA from '~/components/CallCTA.astro';
import RelatedLinks from '~/components/RelatedLinks.astro';
import FAQ from '~/components/FAQ.astro';
import { SERVICES } from '~/data/services';
import { ERROR_CODES } from '~/data/errorCodes';
import { COUNTIES } from '~/data/locations';
import { BUSINESS } from '~/data/business';

export async function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const explicitlyRelated = ERROR_CODES.filter((c) => service.relatedErrorCodes.includes(c.code));
const fallbackCodes = ERROR_CODES.filter((c) => !service.relatedErrorCodes.includes(c.code)).slice(0, 4);
const relatedCodes =
  explicitlyRelated.length >= 3 ? explicitlyRelated : [...explicitlyRelated, ...fallbackCodes].slice(0, 4);
const introParagraphs = service.longIntro.split('\n\n');
---

<Layout
  title={`${service.title} | ${BUSINESS.phoneDisplay}`}
  description={service.metaDescription}
  heroTitle={service.h1}
  heroSubtitle={service.shortDescription}
>
  <div class="maintext">
    {introParagraphs.map((p) => <p>{p}</p>)}
  </div>

  <div class="maintext">
    <h2>Symptoms We Hear Most Often</h2>
    <ul>
      {service.symptoms.map((s) => <li>{s}</li>)}
    </ul>
  </div>

  <div class="maintext">
    <h2>Common Causes on Samsung Refrigerators</h2>
    <ul>
      {service.causes.map((c) => (
        <li>
          <strong style="color:#fff;">{c.title}.</strong> {c.explanation}
        </li>
      ))}
    </ul>
  </div>

  <div class="maintext">
    <h2>How We Diagnose &amp; Repair</h2>
    <ol style="margin-left:50px;">
      {service.repairSteps.map((step) => <li style="margin:0 0 0 0; padding:10px 5px 10px 5px; color:#fff; font-size:1.1em;">{step}</li>)}
    </ol>
  </div>

  {relatedCodes.length > 0 && (
    <div class="maintext">
      <h2>Related Samsung Error Codes</h2>
      <ul>
        {relatedCodes.map((code) => (
          <li>
            <a style="color:#fff; font-weight:700;" href={`/error-codes/${code.slug}/`}>{code.code}</a>
            &nbsp;— {code.meaning}
          </li>
        ))}
      </ul>
    </div>
  )}

  <div class="maintext">
    <h2>When You Should Call vs DIY</h2>
    <p>{service.diyVsCall}</p>
  </div>

  <div class="maintext">
    <h2>Available in All Five Counties</h2>
    <ul>
      {COUNTIES.map((county) => (
        <li>
          <a style="color:#fff; font-weight:700;" href={`/service-area/${county.slug}/`}>
            {service.title.replace('Samsung ', '').replace(' Repair', '')} in {county.name}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <FAQ faqs={service.faq.map((f) => ({ question: f.q, answer: f.a }))} />

  <RelatedLinks excludeServiceSlug={service.slug} />

  <div class="maintext">
    <CallCTA />
  </div>
</Layout>
