---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero.astro';
import FinalCTA from '~/components/FinalCTA.astro';
import Icon from '~/components/Icon.astro';
import { MODELS } from '~/data/models';
import { BUSINESS } from '~/data/business';

const title = `Samsung Refrigerator Models We Repair | ${BUSINESS.phoneDisplay}`;
const description = `Samsung Family Hub, Bespoke, French Door, 4-Door FlexZone, side-by-side, and top-freezer repair. Call ${BUSINESS.phoneDisplay}.`;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Models' },
];

const ICONS: Record<string, Parameters<typeof Icon>[0]['name']> = {
  'family-hub': 'cpu',
  bespoke: 'tag',
  'french-door-4-door-flex': 'snowflake',
  'side-by-side': 'fan',
  'top-freezer': 'thermometer',
};
---

<Layout title={title} description={description} noHero={true}>
  <Hero
    variant="inner"
    breadcrumbs={breadcrumbs}
    title="Samsung Refrigerator Models We Repair"
    subtitle="Family Hub, Bespoke, French Door, 4-Door FlexZone, side-by-side, and top-freezer."
  />

  <section class="section">
    <div class="container">
      <div class="services-grid">
        {MODELS.map((m) => (
          <a class="card service-card card-link" href={`/models/${m.slug}/`}>
            <span class="icon-circle"><Icon name={ICONS[m.slug] ?? 'snowflake'} /></span>
            <h3>{m.title.replace('Samsung ', '').replace(' Refrigerator Repair', '').replace(' Repair', '')}</h3>
            <p>{m.description}</p>
            <span class="btn-ghost">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA />
</Layout>
