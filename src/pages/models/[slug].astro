---
import Layout from '~/layouts/Layout.astro';
import CallCTA from '~/components/CallCTA.astro';
import RelatedLinks from '~/components/RelatedLinks.astro';
import FAQ from '~/components/FAQ.astro';
import { MODELS } from '~/data/models';
import { BUSINESS } from '~/data/business';

export async function getStaticPaths() {
  return MODELS.map((m) => ({
    params: { slug: m.slug },
    props: { model: m },
  }));
}

const { model } = Astro.props;
const description = `${model.description} Samsung repair across ${BUSINESS.areasServed.length} counties. Call ${BUSINESS.phoneDisplay}.`;
const introParagraphs = model.longIntro.split('\n\n');
---

<Layout
  title={`${model.title} | ${BUSINESS.phoneDisplay}`}
  description={description.slice(0, 160)}
  heroTitle={model.title}
  heroSubtitle={model.description}
>
  <div class="maintext">
    {introParagraphs.map((p) => <p>{p}</p>)}
  </div>

  <div class="maintext">
    <h2>Common Issues on This Model</h2>
    <ul>
      {model.commonIssues.map((issue) => <li>{issue}</li>)}
    </ul>
  </div>

  <div class="maintext">
    <h2>Typical Repairs We Perform</h2>
    <ul>
      {model.typicalRepairs.map((r) => <li>{r}</li>)}
    </ul>
  </div>

  <div class="maintext">
    <h2>Available Across {BUSINESS.areasServed.length} Counties</h2>
    <p>
      {BUSINESS.areasServed.join(', ')} — same-day service when available. Call
      <a style="color:#fff; font-weight:700;" href={BUSINESS.phoneTel}>{BUSINESS.phoneDisplay}</a>
      to book.
    </p>
  </div>

  <FAQ faqs={model.faq.map((f) => ({ question: f.q, answer: f.a }))} />

  <RelatedLinks />

  <div class="maintext">
    <CallCTA />
  </div>
</Layout>
