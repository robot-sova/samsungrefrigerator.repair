---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero.astro';
import StickyCTACard from '~/components/StickyCTACard.astro';
import FAQ from '~/components/FAQ.astro';
import FinalCTA from '~/components/FinalCTA.astro';
import { MODELS } from '~/data/models';
import { BUSINESS } from '~/data/business';

export async function getStaticPaths() {
  return MODELS.map((m) => ({
    params: { slug: m.slug },
    props: { model: m },
  }));
}

const { model } = Astro.props;
const description = `${model.description} Samsung repair across ${BUSINESS.areasServed.length} counties. Call ${BUSINESS.phoneDisplay}.`;
const introParagraphs = model.longIntro.split('\n\n');

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Models', href: '/models/' },
  { label: model.title.replace('Samsung ', '').replace(' Refrigerator Repair', '').replace(' Repair', '') },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(c.href ? { item: new URL(c.href, BUSINESS.siteUrl).toString() } : {}),
  })),
};
---

<Layout
  title={`${model.title} | ${BUSINESS.phoneDisplay}`}
  description={description.slice(0, 160)}
  noHero={true}
>
  <Hero
    variant="inner"
    breadcrumbs={breadcrumbs}
    title={model.title}
    subtitle={model.description}
  />

  <div class="container section">
    <div class="page-grid">
      <div class="page-main">
        <div class="prose-block">
          {introParagraphs.map((p) => <p>{p}</p>)}
        </div>

        <div class="prose-block">
          <h2>Common issues on this model</h2>
          <ul>
            {model.commonIssues.map((issue) => <li>{issue}</li>)}
          </ul>
        </div>

        <div class="prose-block">
          <h2>Typical repairs we perform</h2>
          <ul>
            {model.typicalRepairs.map((r) => <li>{r}</li>)}
          </ul>
        </div>

        <div class="prose-block">
          <h2>Available across {BUSINESS.areasServed.length} counties</h2>
          <p>
            {BUSINESS.areasServed.join(', ')} — same-day service when available. Call
            <a href={BUSINESS.phoneTel}><strong>{BUSINESS.phoneDisplay}</strong></a>
            to book.
          </p>
        </div>

        <div class="prose-block">
          <FAQ faqs={model.faq.map((f) => ({ question: f.q, answer: f.a }))} heading="Frequently asked questions" />
        </div>
      </div>

      <aside class="page-sidebar">
        <StickyCTACard context={`Need ${model.title.replace('Samsung ', '').toLowerCase()}? Same-day visits available.`} />
      </aside>
    </div>
  </div>

  <FinalCTA />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
