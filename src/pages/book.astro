---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero.astro';
import StickyCTACard from '~/components/StickyCTACard.astro';
import FinalCTA from '~/components/FinalCTA.astro';
import { BUSINESS } from '~/data/business';

const title = `Book Samsung Refrigerator Repair | ${BUSINESS.phoneDisplay}`;
const description =
  'Book same-day or next-day Samsung refrigerator repair in LA, Orange, Riverside, San Bernardino, or Ventura county. Reply within minutes during business hours.';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Book Online' },
];

// Compute today + max date in PT at build time. Client-side JS recomputes
// these on form load so a cached page doesn't surface a stale "today".
const ptToday = new Intl.DateTimeFormat('en-CA', {
  timeZone: 'America/Los_Angeles',
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(new Date());
const addDays = (ymd: string, n: number): string => {
  const [y, m, d] = ymd.split('-').map((s) => parseInt(s, 10));
  const dt = new Date(Date.UTC(y!, (m! - 1), d!));
  dt.setUTCDate(dt.getUTCDate() + n);
  return dt.toISOString().slice(0, 10);
};
const maxDate = addDays(ptToday, 7);

// Keep these in sync with functions/api/submit-form.ts (TIME_SLOTS).
// The dash is U+2013 EN DASH.
const TIME_SLOTS: { label: string; startHour: number }[] = [
  { label: '8 AM – 10 AM', startHour: 8 },
  { label: '10 AM – 12 PM', startHour: 10 },
  { label: '12 PM – 2 PM', startHour: 12 },
  { label: '2 PM – 4 PM', startHour: 14 },
  { label: '4 PM – 6 PM', startHour: 16 },
  { label: '6 PM – 8 PM', startHour: 18 },
];

// Keep in sync with CALLBACK_WINDOWS in functions/api/submit-form.ts.
const CALLBACK_WINDOWS = [
  'Morning (8 AM – 12 PM)',
  'Afternoon (12 PM – 4 PM)',
  'Evening (4 PM – 8 PM)',
];
---

<Layout title={title} description={description} noHero={true}>
  <Hero
    variant="inner"
    breadcrumbs={breadcrumbs}
    kicker="Same-day service available"
    title="Book Samsung Refrigerator Repair"
    subtitle={`Reply within minutes during business hours (${BUSINESS.hoursDisplay}).`}
  />

  <div class="container section">
    <div class="page-grid">
      <div class="page-main">
        <div class="prose-block" id="bookingFormContainer">
          <p style="margin-bottom: 16px;">
            Fill out the form and we'll text or call you back within minutes during business hours
            (Mon–Sun 8 AM – 8 PM). For faster service call
            <a href={BUSINESS.phoneTel}><strong>{BUSINESS.phoneDisplay}</strong></a>
            directly — booking line is open 24/7.
          </p>

          <form class="booking-form" id="bookingForm" novalidate>
            <div class="field">
              <label for="bf-name">Full name</label>
              <input
                type="text"
                id="bf-name"
                name="name"
                autocomplete="name"
                required
                minlength="2"
                maxlength="100"
              />
            </div>

            <div class="field">
              <label for="bf-phone">Phone</label>
              <input
                type="tel"
                id="bf-phone"
                name="phone"
                autocomplete="tel"
                required
                inputmode="tel"
                pattern="[\d\s().+\-]{10,}"
                placeholder="(424) 407-1019"
              />
              <span class="form-help">We'll text or call back. US numbers only.</span>
            </div>

            <div class="field-row">
              <div class="field">
                <label for="bf-date">Preferred date</label>
                <input
                  type="date"
                  id="bf-date"
                  name="preferredDate"
                  required
                  min={ptToday}
                  max={maxDate}
                  data-build-min={ptToday}
                />
              </div>

              <div class="field">
                <label for="bf-time">Preferred time</label>
                <select id="bf-time" name="preferredTime" required>
                  <option value="" disabled selected>Select a time slot</option>
                  {TIME_SLOTS.map((s) => (
                    <option value={s.label} data-start-hour={s.startHour}>{s.label}</option>
                  ))}
                </select>
                <span class="form-help">
                  We'll confirm the exact arrival window when we call you back.
                </span>
              </div>
            </div>

            <div class="field">
              <label for="bf-description">
                Describe the problem
                <span class="label-hint">(model number helps if you have it)</span>
              </label>
              <textarea
                id="bf-description"
                name="description"
                rows="5"
                required
                minlength="5"
                maxlength="2000"
                placeholder="e.g., Family Hub fridge isn't cooling but freezer is fine. Started yesterday. Model RF28R7351."
              ></textarea>
            </div>

            {/* Honeypot — visually hidden, named both 'website' and 'honeypot' for safety */}
            <div class="honeypot" aria-hidden="true">
              <label for="bf-website">Website</label>
              <input
                type="text"
                id="bf-website"
                name="website"
                tabindex="-1"
                autocomplete="off"
                value=""
              />
            </div>

            <div id="bf-error" class="form-error" hidden></div>

            <button type="submit" class="btn btn-primary" id="bf-submit" style="width:100%;">
              Send booking request
            </button>
          </form>
        </div>

        <section class="callback-block" id="callbackBlock">
          <h3>Prefer a callback instead?</h3>
          <p class="callback-sub">
            Just leave your name and number — we'll call you back. Usually within 15 minutes during
            business hours.
          </p>
          <button type="button" class="btn btn-secondary" id="callback-toggle" aria-expanded="false" aria-controls="callbackForm">
            Request a callback
          </button>

          <div class="callback-form-wrapper" id="callback-wrapper" hidden>
            <form class="booking-form" id="callbackForm" novalidate style="margin-top: 16px;">
              <div class="field">
                <label for="cb-name">Full name</label>
                <input
                  type="text"
                  id="cb-name"
                  name="name"
                  autocomplete="name"
                  required
                  minlength="2"
                  maxlength="100"
                />
              </div>

              <div class="field">
                <label for="cb-phone">Phone</label>
                <input
                  type="tel"
                  id="cb-phone"
                  name="phone"
                  autocomplete="tel"
                  required
                  inputmode="tel"
                  pattern="[\d\s().+\-]{10,}"
                  placeholder="(424) 407-1019"
                />
              </div>

              <div class="field">
                <label for="cb-best">Best time to call</label>
                <select id="cb-best" name="bestTimeToCall">
                  <option value="" selected>Anytime</option>
                  {CALLBACK_WINDOWS.map((w) => (
                    <option value={w}>{w}</option>
                  ))}
                </select>
              </div>

              {/* Honeypot — visually hidden, named both 'website' and 'honeypot' for safety */}
              <div class="honeypot" aria-hidden="true">
                <label for="cb-website">Website</label>
                <input
                  type="text"
                  id="cb-website"
                  name="website"
                  tabindex="-1"
                  autocomplete="off"
                  value=""
                />
              </div>

              <div id="cb-error" class="form-error" hidden></div>

              <button type="submit" class="btn btn-primary" id="cb-submit" style="width:100%;">
                Request callback
              </button>
            </form>
          </div>
        </section>
      </div>

      <aside class="page-sidebar">
        <StickyCTACard heading="Prefer to call?" />
      </aside>
    </div>
  </div>

  <FinalCTA
    heading="Faster than the form?"
    subheading="Call us — we answer the phone 24/7 and book same-day visits when the schedule allows."
  />

  <script type="text/javascript" set:html={`
    (function () {
      // ---- Date + time-slot helpers ----------------------------------------
      function todayPT() {
        return new Intl.DateTimeFormat('en-CA', {
          timeZone: 'America/Los_Angeles',
          year: 'numeric', month: '2-digit', day: '2-digit'
        }).format(new Date());
      }
      function addDays(ymd, n) {
        var parts = ymd.split('-').map(function (s) { return parseInt(s, 10); });
        var dt = new Date(Date.UTC(parts[0], parts[1] - 1, parts[2]));
        dt.setUTCDate(dt.getUTCDate() + n);
        return dt.toISOString().slice(0, 10);
      }
      function currentMinutesPT() {
        var fmt = new Intl.DateTimeFormat('en-US', {
          timeZone: 'America/Los_Angeles',
          hour: '2-digit', minute: '2-digit', hour12: false
        });
        var parts = fmt.formatToParts(new Date()).reduce(function (acc, p) {
          if (p.type !== 'literal') acc[p.type] = p.value;
          return acc;
        }, {});
        var hh = parseInt(parts.hour, 10);
        if (hh === 24) hh = 0; // some Intl builds emit '24' for midnight
        return hh * 60 + parseInt(parts.minute, 10);
      }

      // Recompute date min/max on load to handle stale-cached pages.
      var dateInput = document.getElementById('bf-date');
      var timeSelect = document.getElementById('bf-time');
      if (dateInput) {
        var today = todayPT();
        dateInput.setAttribute('min', today);
        dateInput.setAttribute('max', addDays(today, 7));
        // Clear any stale value below today.
        if (dateInput.value && dateInput.value < today) dateInput.value = '';
      }

      function refreshTimeSlots() {
        if (!dateInput || !timeSelect) return;
        var today = todayPT();
        var isToday = dateInput.value === today;
        var nowMins = currentMinutesPT();
        var threshold = nowMins + 60; // disable slots starting within 60 min
        var anyAvailable = false;
        var options = timeSelect.querySelectorAll('option[data-start-hour]');
        for (var i = 0; i < options.length; i++) {
          var opt = options[i];
          var startMins = parseInt(opt.getAttribute('data-start-hour'), 10) * 60;
          var label = opt.getAttribute('data-base-label') || opt.value;
          opt.setAttribute('data-base-label', label);
          if (isToday && startMins <= threshold) {
            opt.disabled = true;
            opt.textContent = label + ' (unavailable)';
          } else {
            opt.disabled = false;
            opt.textContent = label;
            anyAvailable = true;
          }
        }
        // If the chosen slot is now disabled, reset to placeholder.
        var selected = timeSelect.options[timeSelect.selectedIndex];
        if (selected && selected.disabled) {
          timeSelect.selectedIndex = 0;
        }
        // If today has zero availability left, nudge users by leaving placeholder.
        if (!anyAvailable && isToday) {
          timeSelect.selectedIndex = 0;
        }
      }

      if (dateInput) {
        dateInput.addEventListener('change', refreshTimeSlots);
        refreshTimeSlots();
      }

      // ---- Shared submit handler ------------------------------------------
      var fallbackError =
        "Couldn't send your request. Please call ${BUSINESS.phoneDisplay} or email ${BUSINESS.email}.";

      function bindForm(opts) {
        var form = document.getElementById(opts.formId);
        if (!form) return;
        var btn = document.getElementById(opts.btnId);
        var errorBox = document.getElementById(opts.errorId);

        function showError(msg) {
          if (!errorBox) return;
          errorBox.textContent = msg;
          errorBox.hidden = false;
        }
        function clearError() {
          if (!errorBox) return;
          errorBox.textContent = '';
          errorBox.hidden = true;
        }

        function showSuccess() {
          var container = document.getElementById(opts.containerId);
          if (!container) return;
          var html =
            '<div class="prose-block booking-success">' +
              '<span class="icon-circle">' +
                '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>' +
              '</span>' +
              '<h2>' + opts.successHeading + '</h2>' +
              '<p>' + opts.successBody + '</p>' +
              '<a class="btn btn-secondary" href="/">Back to home</a>' +
            '</div>';
          container.innerHTML = html;
        }

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          clearError();
          if (!btn) return;
          btn.disabled = true;
          btn.textContent = 'Sending…';

          var data = { type: opts.type, source: window.location.pathname || '/book/' };
          var els = form.elements;
          for (var i = 0; i < els.length; i++) {
            var el = els[i];
            if (!el.name) continue;
            data[el.name] = el.value;
          }

          fetch('/api/submit-form', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(data)
          })
            .then(function (res) { return res.json().catch(function () { return { success: false }; }); })
            .then(function (json) {
              if (json && json.success) {
                showSuccess();
              } else {
                showError((json && json.error) ? json.error : fallbackError);
                btn.disabled = false;
                btn.textContent = opts.submitLabel;
              }
            })
            .catch(function () {
              showError(fallbackError);
              btn.disabled = false;
              btn.textContent = opts.submitLabel;
            });
        });
      }

      bindForm({
        formId: 'bookingForm',
        btnId: 'bf-submit',
        errorId: 'bf-error',
        containerId: 'bookingFormContainer',
        type: 'booking',
        submitLabel: 'Send booking request',
        successHeading: 'Thanks — we got it.',
        successBody: "We'll be in touch within minutes during business hours. For urgent service, call ${BUSINESS.phoneDisplay}."
      });

      bindForm({
        formId: 'callbackForm',
        btnId: 'cb-submit',
        errorId: 'cb-error',
        containerId: 'callbackBlock',
        type: 'callback',
        submitLabel: 'Request callback',
        successHeading: "Thanks — we'll call you back shortly.",
        successBody: "We'll be in touch within 15 minutes during business hours. For urgent service, call ${BUSINESS.phoneDisplay}."
      });

      // ---- Callback toggle -------------------------------------------------
      var toggleBtn = document.getElementById('callback-toggle');
      var wrapper = document.getElementById('callback-wrapper');
      if (toggleBtn && wrapper) {
        toggleBtn.addEventListener('click', function () {
          var willOpen = wrapper.hasAttribute('hidden');
          if (willOpen) {
            wrapper.removeAttribute('hidden');
            toggleBtn.setAttribute('aria-expanded', 'true');
            toggleBtn.textContent = 'Hide callback form';
            var nameInput = document.getElementById('cb-name');
            if (nameInput) nameInput.focus();
          } else {
            wrapper.setAttribute('hidden', '');
            toggleBtn.setAttribute('aria-expanded', 'false');
            toggleBtn.textContent = 'Request a callback';
          }
        });
      }
    })();
  `}></script>
</Layout>
