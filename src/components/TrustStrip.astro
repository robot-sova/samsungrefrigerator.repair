---
import Icon from './Icon.astro';

const items = [
  'Same-day service available',
  '5 counties served',
  'Mon–Sun 8 AM – 8 PM',
  'Booking 24/7',
  'Samsung specialists since 2010',
];
---

<section class="trust-strip">
  <div class="container">
    <div class="trust-strip__row">
      {items.map((label) => (
        <div class="trust-strip__item">
          <Icon name="check-circle" size={20} />
          {label}
        </div>
      ))}
    </div>
  </div>
</section>
