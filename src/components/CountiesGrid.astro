---
import { COUNTIES } from '~/data/locations';

export interface Props {
  heading?: string;
}

const { heading = 'Counties We Serve' } = Astro.props;
---

<div class="maintext" id="areas">
  <h2>{heading}</h2>
  <ul role="list" style="margin-left:30px;">
    {COUNTIES.map((county) => (
      <li>
        <a style="color:#fff; font-weight:700;" href={`/service-area/${county.slug}/`}>
          {county.name}
        </a>
        <span style="color:#cfcfcf;"> — {county.cities.length} cities served</span>
      </li>
    ))}
  </ul>
</div>
