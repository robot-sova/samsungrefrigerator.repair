---
import { SERVICES } from '~/data/services';
import { ERROR_CODES } from '~/data/errorCodes';
import { findCounty } from '~/data/locations';

export interface Props {
  countySlug?: string;
  citySlug?: string;
  excludeServiceSlug?: string;
  excludeErrorCodeSlug?: string;
}

const { countySlug, citySlug, excludeServiceSlug, excludeErrorCodeSlug } = Astro.props;

const services = SERVICES.filter((s) => s.slug !== excludeServiceSlug).slice(0, 6);
const errorCodes = ERROR_CODES.filter((c) => c.slug !== excludeErrorCodeSlug).slice(0, 6);

let nearbyCities: { slug: string; name: string; countySlug: string }[] = [];
if (countySlug && citySlug) {
  const county = findCounty(countySlug);
  if (county) {
    const idx = county.cities.findIndex((ct) => ct.slug === citySlug);
    if (idx >= 0) {
      const before = county.cities.slice(Math.max(0, idx - 2), idx);
      const after = county.cities.slice(idx + 1, idx + 4);
      nearbyCities = [...before, ...after]
        .slice(0, 3)
        .map((ct) => ({ slug: ct.slug, name: ct.name, countySlug: county.slug }));
    }
  }
}
---

<div class="maintext">
  <h2>Related Information</h2>

  <h3>Repair Services</h3>
  <ul role="list" style="margin-left:30px;">
    {services.map((s) => (
      <li><a style="color:#fff;" href={`/services/${s.slug}/`}>{s.title}</a></li>
    ))}
  </ul>

  {nearbyCities.length > 0 && (
    <>
      <h3>Nearby Cities</h3>
      <ul role="list" style="margin-left:30px;">
        {nearbyCities.map((city) => (
          <li>
            <a style="color:#fff;" href={`/service-area/${city.countySlug}/${city.slug}/`}>
              Samsung Refrigerator Repair in {city.name}
            </a>
          </li>
        ))}
      </ul>
    </>
  )}

  <h3>Error Codes</h3>
  <ul role="list" style="margin-left:30px;">
    {errorCodes.map((code) => (
      <li><a style="color:#fff;" href={`/error-codes/${code.slug}/`}>{code.code}</a> — {code.title.replace(`Samsung ${code.code} Error — `, '').replace(`Samsung ${code.code} — `, '')}</li>
    ))}
  </ul>
</div>
