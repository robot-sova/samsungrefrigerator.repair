    | 'clock'
    | 'map-pin'
    | 'shield'
    | 'tag'
    | 'globe'
    | 'facebook'
    | 'youtube'
    | 'instagram';
  size?: number;
  class?: string;
  ariaHidden?: boolean;
  ariaLabel?: string;
}

const { name, size = 20, class: className = '', ariaHidden = true, ariaLabel } = Astro.props;

type Path = string | string[];
const PATHS: Record<Props['name'], Path> = {
