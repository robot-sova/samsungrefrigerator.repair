    'M19.07 4.93a10 10 0 0 1 0 14.14',
    'M15.54 8.46a5 5 0 0 1 0 7.07',
  ],
  'door-open': [
    'M13 4h3a2 2 0 0 1 2 2v14',
    'M2 20h3',
    'M13 20h9',
    'M10 12v.01',
    'M13 4.562v16.157a1 1 0 0 1-1.242.97L5 20V5.562a2 2 0 0 1 1.515-1.94l4-1A2 2 0 0 1 13 4.561Z',
  ],
