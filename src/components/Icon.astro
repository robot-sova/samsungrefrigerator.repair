---
// Inline Lucide-style SVG icons. No runtime, no deps.
export interface Props {
  name:
    | 'phone'
    | 'check'
    | 'check-circle'
    | 'menu'
    | 'x'
    | 'chevron-down'
    | 'chevron-right'
    | 'arrow-right'
    | 'star'
    | 'snowflake'
    | 'droplet'
    | 'thermometer'
    | 'cpu'
    | 'wrench'
    | 'volume-2'
    | 'door-open'
    | 'alert-triangle'
    | 'fan'
