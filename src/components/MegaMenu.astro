---
import { SERVICES } from '~/data/services';
import { ERROR_CODES } from '~/data/errorCodes';
import { MODELS } from '~/data/models';
import { COUNTIES } from '~/data/locations';
import Icon from './Icon.astro';

const SERVICE_ICONS: Record<string, Parameters<typeof Icon>[0]['name']> = {
  'not-cooling': 'thermometer',
  'ice-maker-repair': 'snowflake',
  'water-leak': 'droplet',
  'freezer-not-freezing': 'snowflake',
  'compressor-repair': 'cpu',
  'control-board-repair': 'cpu',
  'door-seal-repair': 'door-open',
  'noisy-refrigerator': 'volume-2',
  'error-code-repair': 'alert-triangle',
};

const MODEL_ICONS: Record<string, Parameters<typeof Icon>[0]['name']> = {
  'family-hub': 'cpu',
  bespoke: 'tag',
  'french-door-4-door-flex': 'snowflake',
  'side-by-side': 'fan',
  'top-freezer': 'thermometer',
};
---

<ul class="nav-primary">
  <li class="nav-primary__item">
    <a class="nav-primary__link" href="/services/" aria-haspopup="true" aria-expanded="false">
      Services
      <Icon name="chevron-down" size={14} class="nav-primary__caret" />
    </a>
    <div class="mega-panel" role="menu" aria-label="Services menu">
      <div class="mega-panel__grid mega-panel__grid--3col">
        {SERVICES.map((s) => (
          <a class="mega-panel__item" href={`/services/${s.slug}/`}>
            <span class="icon-circle"><Icon name={SERVICE_ICONS[s.slug] ?? 'wrench'} /></span>
            <span>
              <span class="mega-panel__item-title">{s.title.replace('Samsung ', '').replace(' Repair', '')}</span>
              <span class="mega-panel__item-desc">{s.shortDescription}</span>
            </span>
          </a>
        ))}
      </div>
      <div class="mega-panel__footer">
        <a href="/services/">View all services →</a>
      </div>
    </div>
  </li>

  <li class="nav-primary__item">
    <a class="nav-primary__link" href="/models/" aria-haspopup="true" aria-expanded="false">
      Models
      <Icon name="chevron-down" size={14} class="nav-primary__caret" />
    </a>
    <div class="mega-panel" role="menu" aria-label="Models menu" style="min-width: 760px;">
      <div class="mega-panel__grid mega-panel__grid--5col">
        {MODELS.map((m) => (
          <a class="mega-panel__item" href={`/models/${m.slug}/`} style="flex-direction: column; text-align: center;">
            <span class="icon-circle" style="margin: 0 auto 8px auto;"><Icon name={MODEL_ICONS[m.slug] ?? 'snowflake'} /></span>
            <span>
              <span class="mega-panel__item-title">{m.title.replace('Samsung ', '').replace(' Refrigerator Repair', '').replace(' Repair', '')}</span>
            </span>
          </a>
        ))}
      </div>
      <div class="mega-panel__footer">
        <a href="/models/">View all models →</a>
      </div>
    </div>
  </li>

  <li class="nav-primary__item">
    <a class="nav-primary__link" href="/error-codes/" aria-haspopup="true" aria-expanded="false">
      Error Codes
      <Icon name="chevron-down" size={14} class="nav-primary__caret" />
    </a>
    <div class="mega-panel" role="menu" aria-label="Error codes menu">
      <div class="mega-panel__grid mega-panel__grid--3col">
        {ERROR_CODES.map((c) => (
          <a class="mega-panel__item" href={`/error-codes/${c.slug}/`}>
            <span class="icon-circle"><Icon name="alert-triangle" /></span>
            <span>
              <span class="mega-panel__item-title">{c.code}</span>
              <span class="mega-panel__item-desc">{c.title.replace(`Samsung ${c.code} Error — `, '').replace(`Samsung ${c.code} — `, '')}</span>
            </span>
          </a>
        ))}
      </div>
      <div class="mega-panel__footer">
        <a href="/error-codes/">View error code reference →</a>
      </div>
    </div>
  </li>

  <li class="nav-primary__item">
    <a class="nav-primary__link" href="/service-area/" aria-haspopup="true" aria-expanded="false">
      Service Area
      <Icon name="chevron-down" size={14} class="nav-primary__caret" />
    </a>
    <div class="mega-panel" role="menu" aria-label="Service area menu" style="min-width: 920px;">
      <div class="mega-panel__grid mega-panel__grid--5col">
        {COUNTIES.map((county) => (
          <div>
            <div class="mega-panel__col-title">{county.name.replace(' County', '')}</div>
            <ul class="mega-panel__col-list">
              {county.cities.slice(0, 5).map((city) => (
                <li>
                  <a href={`/service-area/${county.slug}/${city.slug}/`}>{city.name}</a>
                </li>
              ))}
            </ul>
            <a href={`/service-area/${county.slug}/`} style="font-size: 0.85rem; font-weight: 700;">
              All {county.name.replace(' County', '')} →
            </a>
          </div>
        ))}
      </div>
      <div class="mega-panel__footer">
        <a href="/service-area/">View full service area →</a>
      </div>
    </div>
  </li>

  <li class="nav-primary__item">
    <a class="nav-primary__link" href="/about/">About</a>
  </li>
</ul>
