---
import { findCounty } from '~/data/locations';

export interface Props {
  countySlug: string;
  heading?: string;
}

const { countySlug, heading } = Astro.props;
const county = findCounty(countySlug);
if (!county) {
  throw new Error(`CitiesGrid: county not found: ${countySlug}`);
}
const title = heading ?? `Cities We Serve in ${county.name}`;
---

<div class="maintext">
  <h2>{title}</h2>
  <ul role="list" style="margin-left:30px;">
    {county.cities.map((city) => (
      <li>
        <a style="color:#fff; font-weight:700;" href={`/service-area/${county.slug}/${city.slug}/`}>
          Samsung Refrigerator Repair in {city.name}
        </a>
      </li>
    ))}
  </ul>
</div>
