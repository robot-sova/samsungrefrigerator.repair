---
import { BUSINESS } from '~/data/business';
import Icon from './Icon.astro';

export interface Props {
  callLabel?: string;
  bookLabel?: string;
  align?: 'left' | 'center';
}

const {
  callLabel = `Call ${BUSINESS.phoneDisplay}`,
  bookLabel = 'Book Online',
  align = 'left',
} = Astro.props;
---

<div style={`display:flex; gap:12px; flex-wrap:wrap; margin: 16px 0; ${align === 'center' ? 'justify-content:center;' : ''}`}>
  <a class="btn btn-primary" href={BUSINESS.phoneTel}>
    <Icon name="phone" size={18} />
    {callLabel}
  </a>
  <a class="btn btn-secondary" href="/book">{bookLabel}</a>
</div>
