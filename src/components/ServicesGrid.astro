---
import { SERVICES } from '~/data/services';

export interface Props {
  heading?: string;
  excludeSlug?: string;
}

const { heading = 'Samsung Refrigerator Repair Services', excludeSlug } = Astro.props;
const items = excludeSlug ? SERVICES.filter((s) => s.slug !== excludeSlug) : SERVICES;
---

<div class="maintext">
  <h2>{heading}</h2>
  <ul role="list" style="margin-left:30px;">
    {items.map((s) => (
      <li>
        <a style="color:#fff; font-weight:700;" href={`/services/${s.slug}/`}>{s.title}</a>
        <br />
        <span style="color:#cfcfcf; font-size:0.95em;">{s.shortDescription}</span>
      </li>
    ))}
  </ul>
</div>
