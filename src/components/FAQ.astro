---
import FAQSchema from './FAQSchema.astro';

export interface FAQItem {
  question: string;
  answer: string;
}

export interface Props {
  faqs: FAQItem[];
  heading?: string;
  intro?: string;
  asSection?: boolean;
}

const {
  faqs,
  heading = 'Frequently asked questions',
  intro,
  asSection = false,
} = Astro.props;
---

{asSection ? (
  <section class="section">
    <div class="container">
      <div class="section-head">
        {heading && <h2>{heading}</h2>}
        {intro && <p>{intro}</p>}
      </div>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.question}</summary>
            <p>{f.answer}</p>
          </details>
        ))}
      </div>
    </div>
    <FAQSchema faqs={faqs} />
  </section>
) : (
  <div>
    {heading && <h2>{heading}</h2>}
    {intro && <p>{intro}</p>}
    <div class="faq-list" style="margin-top: 16px;">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.question}</summary>
          <p>{f.answer}</p>
        </details>
      ))}
    </div>
    <FAQSchema faqs={faqs} />
  </div>
)}
